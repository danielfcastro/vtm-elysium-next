{
  "name": "vtm-elysium-next",
  "private": true,
  "version": "2.2.0",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3000",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "fix": "npm run format && npm run lint:fix",
    "type-check": "tsc --noEmit",
    "check": "npm run format:check && npm run lint && npm run type-check",
    "test": "jest",
    "build": "npm run type-check && npm run format:check && npm run lint && next build",
    "start": "next start",
    "docs": "typedoc --entryPoints src/ --out docs --clean --tsconfig tsconfig.json",
    "css:sort": "postcss \"**/*.css\" --use css-declaration-sorter --replace --no-map",
    "css:sort:modules": "postcss \"**/*.module.css\" --use css-declaration-sorter --replace --no-map",
    "css:sort:rules": "postcss \"app/character-sheet.css\" --config postcss.rulesort.config.cjs --replace --no-map",
    "css:sort:structure": "postcss \"**/*.css\" --config postcss.sorting.config.cjs --replace --no-map",
    "css:sort:selectors": "node scripts/sort-css-selectors.cjs \"app/**/*.css\" \"styles/**/*.css\" \"src/**/*.css\"",
    "prepare": "husky",
    "version": "node scripts/update-readme-version.cjs",
    "postversion": "git add README.md"
  },
  "postcss": {
    "syntax": "postcss-scss",
    "map": false,
    "plugins": {
      "css-declaration-sorter": {
        "order": "smacss"
      }
    }
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.2.3",
    "fs": "^0.0.1-security",
    "jose": "^6.1.3",
    "jsonwebtoken": "^9.0.3",
    "next": "^16.1.6",
    "pg": "^8.16.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "swagger-jsdoc": "^6.2.8",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "css-declaration-sorter": "^7.3.0",
    "eslint": "^9.18.0",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "fast-glob": "^3.3.3",
    "husky": "^9.1.7",
    "jest": "29.7.0",
    "lint-staged": "^16.3.2",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "postcss-sort-style-rules": "^0.2.0",
    "prettier": "^3.8.0",
    "prettier-plugin-css-order": "^2.1.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "ts-jest": "29.2.5",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.17",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.19.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss,md,json}": "prettier --write"
  }
}
